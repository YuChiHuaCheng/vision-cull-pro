{
  "name": "vision-cull-pro",
  "version": "1.0.0",
  "description": "Local Event Photo Culler - local vision algorithms to discard blurred or closed-eye photos",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.visioncull.pro",
    "productName": "VisionCull Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!venv311${/*}",
      "!venv${/*}",
      "!__pycache__${/*}",
      "!**/*.py",
      "!**/*.spec",
      "!**/*.md",
      "!requirements.txt"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "extraResources": [
      {
        "from": "dist/analyzer",
        "to": "bin/analyzer"
      }
    ]
  }
}